{
  "name": "@defchigga/reset.css",
  "version": "1.0.3",
  "description": "A modern and concise CSS reset and normalization library that provides a consistent styling foundation for web projects.",
  "keywords": [
    "css",
    "reset",
    "normalize",
    "sanitize",
    "style",
    "web",
    "frontend"
  ],
  "main": "reset.css",
  "style": "reset.css",
  "module": "reset.css",
  "types": "reset.css.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "style": "./reset.css",
      "import": "./reset.css",
      "require": "./reset.css",
      "default": "./reset.css"
    }
  },
  "files": [
    "reset.css",
    "reset.css.d.ts"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "author": "DefChigga <defchigga@qq.com>",
  "homepage": "https://github.com/Def-Chigga/reset.css#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Def-Chigga/reset.css.git"
  },
  "bugs": {
    "url": "https://github.com/Def-Chigga/reset.css/issues",
    "email": "defchigga@qq.com"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup": "^4.50.2",
    "rollup-plugin-clean": "^1.0.0",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-postcss": "^4.0.2"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
